# AI model routing. Leave empty until the provider adapter is connected.
AI_TRIAGE_MODEL=
AI_SUMMARY_MODEL=
AI_DRAFT_MODEL=
AI_SAFETY_MODEL=
AI_EMBEDDING_MODEL=

# Mail provider credentials. Use OAuth for Gmail/Microsoft when implemented.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_REDIRECT_URI=http://localhost:4173/

# Notifications. Default is in_app, so WhatsApp Business is not required.
ALERT_PROVIDER=in_app
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
SMS_PROVIDER=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=

# Server
PORT=4173

# Target mailbox. Put your own address in local .env, not secrets in Git.
MAILBOX_EMAIL=your.email@gmail.com

# Gmail OAuth. Store real files in private/, which is ignored by Git.
GMAIL_ENABLED=false
GMAIL_CREDENTIALS_PATH=private/gmail_credentials.json
GMAIL_TOKEN_PATH=private/gmail_token.json
GMAIL_REDIRECT_URI=http://localhost:4173/auth/google/callback

# Draft attachments. Put your approved CV and other attachments here.
CV_FILE_PATH=private/cv.pdf
DRAFT_ATTACHMENTS_DIR=private/attachments
